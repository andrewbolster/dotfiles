[commit]
	gpgsign = true
[pull]
	rebase = true
[color]
	status = always
	diff = always
[gpg]
	program = gpg

[includeIf "hasconfig:remote.*.url:git@github.com:bd-internal/**"]
	path = ~/.gitconfig-bolster_quack

[includeIf "hasconfig:remote.*.url:https://github.com/bd-internal/**"]
	path = ~/.gitconfig-bolster_quack
