{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_DISABLE_EXPERIMENTAL_BETAS": "1",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1"
  },
  "permissions": {
    "allow": [
      "Bash(find :*)",
      "Bash(git :*)",
      "Bash(rg :*)",
      "Bash(uv :*)",
      "Bash(uvx :*)",
      "Bash(grep :*)",
      "Bash(make :*)",
      "Bash(gh :*)",
      "Bash(curl :*)",
      "Read",
      "Edit",
      "Write",
      "WebFetch",
      "Bash(git fetch *)",
      "Bash(git checkout *)",
      "Bash(git pull *)",
      "Bash(cat)",
      "Bash(uv run *)",
      "Bash(python3 -c \"import sys; data=sys.stdin.read\\(\\); print\\(repr\\(data\\)\\)\")"
    ],
    "deny": []
  },
  "model": "claude-sonnet-4-6",
  "hooks": {},
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "pptduck@agent-powerups": true,
    "superduck@bd-internal-claude-marketplace": true,
    "polaris@bd-internal-claude-marketplace": true
  },
  "extraKnownMarketplaces": {
    "bd-internal-claude-marketplace": {
      "source": {
        "source": "github",
        "repo": "bd-internal/claude-marketplace"
      }
    }
  },
  "alwaysThinkingEnabled": false,
  "autoUpdatesChannel": "stable",
  "skipDangerousModePermissionPrompt": true,
  "verbose": true,
  "mcpServers": {
    "memory": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-memory"
      ]
    },
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "%HOME%"
      ]
    },
    "ddg-search": {
      "command": "uvx",
      "args": [
        "duckduckgo-mcp-server"
      ],
      "env": {
        "DDG_SAFE_SEARCH": "OFF"
      }
    },
    "bolster": {
      "type": "http",
      "url": "https://mcp.bolster.online/mcp/"
    },
    "service-mcp": {
      "type": "http",
      "url": "https://service-mcp-app.nicefield-9cf5f7f2.eastus.azurecontainerapps.io/mcp/",
      "headers": {
        "Authorization": "Bearer ${MCP_STATIC_ACCESS_TOKEN}"
      }
    },
    "atlassian": {
      "type": "http",
      "url": "https://mcp.atlassian.com/v1/mcp"
    },
    "vantage": {
      "type": "sse",
      "url": "https://mcp.vantage.sh/sse"
    }
  }
}
